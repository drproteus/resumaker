<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="keywords" content="{{.Keywords}}" />
    <style>
    {{.Style}}
    </style>
</html>

</head>

<body>
    <div id="container">
        <div id="contact">
            <ul>
                <li>
                    {{ if .Telephone }}<a href="tel:{{.Telephone}}">{{.Telephone}}</a>
                    ·{{ end }} <a href="mailto:{{.Email}}">{{.Email}}</a> ·
                    {{ if .Website }}
                    <a href="{{.Website}}">{{.Website}}</a>
                    {{ end }}
                </li>
            </ul>
        </div>
        <h1>{{.Fullname}}</h1>
        <div id="diz">
            <img src="https://static.skinet.org/images/dizbanner.png" />
        </div>
        <div id="resume">
            <div class="entry"></div>
            {{ if .Experience }}
            <div class="entry">
                <div class="title">Experience</div>
                <div class="content">
                    <!-- Experience entries -->
                    {{range .Experience}}
                    <b>{{.Title}} · {{.Company}} · {{.Location}}<br>
                        {{.StartDate}} - {{.EndDate}}<br></b>
                    <p>
                    <ul>
                        {{range .Highlights}}
                        <li>{{.}}</li>
                        {{ end }}
                    </ul>
                    </p>
                    {{ end }}
                </div>
            </div>
            {{ end }}
            {{ if .Education }}
            <div class="entry">
                <div class="title">Education</div>
                <div class="content">
                    <!-- Education entries -->
                    {{range .Education}}
                    <b>{{.School}} · {{.Degree}}</b><br />
                    <p>{{range .Highlights}}{{.}}<br />{{end}}</p>
                    {{ end }}
                </div>
            </div>
            {{ end }}
            {{ if .Skills }}
            <div class="entry">
                <div class="title">Skills</div>
                <div class="content">
                    <!-- Skill entries -->
                    {{range $index, $element := .Skills}}{{if $index}}, {{end}}{{$element}}{{end}}
                </div>
            </div>
            {{ end }}
            <br /><br />
        </div>
        <div id="footer">
            <a href="https://github.com/drproteus/resumaker">[view source]</a>
            <a href="resume.pdf">[print]</a>
        </div>
    </div>
</body>

</html>
